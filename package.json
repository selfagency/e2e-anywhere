{
  "name": "e2e-anywhere",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "release:blockers": "node ./scripts/check-release-blockers.mjs",
    "lint": "pnpm -r --if-present lint && oxlint .",
    "lint:fix": "pnpm -r --if-present lint:fix && oxlint --fix .",
    "format": "pnpm -r --if-present format && oxfmt .",
    "format:check": "pnpm -r --if-present format:check && oxfmt --check .",
    "typecheck": "pnpm exec tsc -b --pretty false",
    "test": "pnpm -r --if-present test && vitest run --passWithNoTests",
    "build": "pnpm -r --if-present build && node ./scripts/build.mjs",
    "audit": "pnpm audit --audit-level high"
  },
  "devDependencies": {
    "@types/chrome": "0.1.37",
    "@types/node": "25.3.3",
    "@vitest/browser": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint-plugin-security": "^4.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-web-extension": "4.5.0",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "pnpm exec oxlint --fix",
      "pnpm exec oxfmt"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "pnpm exec oxfmt"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
